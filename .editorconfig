# Top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# C# files
[*.cs]
charset = utf-8

# Project files
[*.csproj]
charset = utf-8

# JSON files
[*.json]
charset = utf-8

# YAML files
[*.{yml,yaml}]
charset = utf-8
indent_size = 2
